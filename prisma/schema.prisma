// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  CLIENT
  EDITOR
  SCRIPTWRITER
  GRAPHIC_DESIGNER
  WEB_DESIGNER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContentType {
  REEL
  POSTER
  STORY
  VIDEO
  GRAPHIC
}

enum ContentStatus {
  IDEA
  SCRIPTING
  SHOOTING
  EDITING
  REVIEW
  POSTED
}

enum EventType {
  MEETING
  SHOOT
  DEADLINE
  REVIEW
  CALL
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  CLIENT_PAYMENT
  SALARY
  EQUIPMENT
  SOFTWARE
  MARKETING
  TRAVEL
  RENT
  UTILITIES
  OTHER
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  phone        String?   @unique
  email        String?   @unique
  password     String
  role         Role      @default(EMPLOYEE)
  name         String
  avatar       String?
  isActive     Boolean   @default(true)
  // Google Calendar: null = no reminder, any positive int = popup X minutes before
  calendarReminderMins Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tasksAssigned   Task[]    @relation("AssignedTo")
  tasksCreated    Task[]    @relation("CreatedBy")
  projects        Project[] @relation("ClientProjects")
  contentItems    Content[] @relation("ContentAssignee")
  contentCreated  Content[] @relation("ContentCreator")
  events          Event[]   @relation("EventOwner")
  notes            Note[]    @relation("NoteOwner")
  transactions     Transaction[] @relation("TransactionOwner")
  reports          DailyReport[] @relation("ReportOwner")
  notifications    Notification[] @relation("NotificationRecipient")
  gcalToken        GoogleCalendarToken?
  invoicesCreated  Invoice[]     @relation("OwnerInvoices")
  invoicesReceived Invoice[]     @relation("ClientInvoices")
  timeLogs         TimeLog[]
  sopCompleted     SopProgress[]

  // CRM relations
  crmCompaniesCreated  CrmCompany[]  @relation("CrmCompanyCreator")
  crmContactsCreated   CrmContact[]  @relation("CrmContactCreator")
  crmLeadsAssigned     CrmLead[]     @relation("CrmLeadAssignee")
  crmLeadsCreated      CrmLead[]     @relation("CrmLeadCreator")
  crmDealsAssigned     CrmDeal[]     @relation("CrmDealAssignee")
  crmDealsCreated      CrmDeal[]     @relation("CrmDealCreator")
  crmActivitiesCreated CrmActivity[] @relation("CrmActivityCreator")

  // Performance indexes — role and isActive are filtered on almost every query
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_calendar_tokens")
}

// Tracks which Google Calendar event corresponds to each task/content item per user.
// This allows us to update or delete the event when the item changes.
model CalendarEventLink {
  id          String   @id @default(cuid())
  userId      String
  entityType  String   // 'task' | 'content'
  entityId    String
  role        String   // 'assignee' | 'manager'
  gcalEventId String
  createdAt   DateTime @default(now())

  @@unique([userId, entityType, entityId, role])
  @@index([entityType, entityId])
  @@map("calendar_event_links")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  clientId    String?
  startDate   DateTime?
  dueDate     DateTime?
  driveFolder String?       // Google Drive folder URL for this project
  boardColumn String        @default("ACTIVE")  // tracks kanban stage
  sopLevel    Int?          // 1–7 matching the SOP pipeline levels
  value       Decimal?      @db.Decimal(12, 2)  // project monetary value
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  client       User?     @relation("ClientProjects", fields: [clientId], references: [id])
  tasks        Task[]
  content      Content[]
  events       Event[]
  notes        Note[]
  transactions Transaction[]
  crmLeads     CrmLead[]
  crmDeals     CrmDeal[]
  invoices     Invoice[]
  sopProgress  SopProgress[]

  // Performance indexes
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}


model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  deadline     DateTime?
  assignedToId String?
  createdById  String
  projectId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  assignedTo   User?    @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy    User     @relation("CreatedBy", fields: [createdById], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
  timeLogs     TimeLog[]

  // Performance indexes — most common query patterns
  @@index([assignedToId])
  @@index([projectId])
  @@index([status])
  @@index([deadline])
  @@index([createdAt])
  @@map("tasks")
}

model Content {
  id               String        @id @default(cuid())
  title            String
  type             ContentType
  status           ContentStatus @default(IDEA)
  description      String?
  driveLink        String?
  scriptLink       String?
  scriptApproved   Boolean       @default(false)
  scriptApprovedBy String?
  caption          String?
  postDate         DateTime?
  assigneeId       String?
  createdById      String
  projectId        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  assignee     User?    @relation("ContentAssignee", fields: [assigneeId], references: [id])
  createdBy    User     @relation("ContentCreator", fields: [createdById], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
  metrics      ContentMetrics[]

  // Performance indexes — most common query patterns
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([postDate])
  @@index([createdAt])
  @@map("content")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(MEETING)
  startTime   DateTime
  endTime     DateTime
  location    String?
  meetingLink String?
  ownerId     String
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User     @relation("EventOwner", fields: [ownerId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([startTime])
  @@index([ownerId])
  @@map("events")
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")
  icon        String?  @default("📝")
  pinned      Boolean  @default(false)
  tags        String[] @default([])
  ownerId     String
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation("NoteOwner", fields: [ownerId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([ownerId])
  @@map("notes")
}

model Transaction {
  id          String              @id @default(cuid())
  title       String
  amount      Decimal             @db.Decimal(12, 2)
  type        TransactionType
  category    TransactionCategory @default(OTHER)
  notes       String?
  date        DateTime            @default(now())
  ownerId     String
  projectId   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  owner       User     @relation("TransactionOwner", fields: [ownerId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([date])
  @@index([ownerId])
  @@map("transactions")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMPLETED
  CONTENT_ASSIGNED
  CONTENT_SCHEDULED
  CONTENT_POSTED
  PROJECT_ASSIGNED
  PROJECT_UPDATED
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model DailyReport {
  id           String   @id @default(cuid())
  ownerId      String
  date         DateTime @db.Date
  summary      String
  hoursWorked  Float?
  blockers     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User     @relation("ReportOwner", fields: [ownerId], references: [id])

  @@unique([ownerId, date])
  @@index([date])
  @@map("daily_reports")
}

// ─── CRM Module ──────────────────────────────────────────────────────────────

model CrmCompany {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  website     String?
  address     String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  createdBy   User?        @relation("CrmCompanyCreator", fields: [createdById], references: [id])
  contacts    CrmContact[]
  leads       CrmLead[]
  deals       CrmDeal[]

  @@map("crm_companies")
}

model CrmContact {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  position    String?
  companyId   String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  company     CrmCompany?   @relation(fields: [companyId], references: [id])
  createdBy   User?         @relation("CrmContactCreator", fields: [createdById], references: [id])
  leads       CrmLead[]
  deals       CrmDeal[]
  activities  CrmActivity[]

  @@map("crm_contacts")
}

model CrmLead {
  id                String   @id @default(cuid())
  title             String
  stage             String   @default("NEW")
  source            String   @default("OTHER")
  value             Decimal? @db.Decimal(12, 2)
  contactId         String?
  companyId         String?
  assignedToId      String?
  projectId         String?
  notes             String?
  expectedCloseDate DateTime? @db.Date
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  contact     CrmContact? @relation(fields: [contactId], references: [id])
  company     CrmCompany? @relation(fields: [companyId], references: [id])
  assignedTo  User?       @relation("CrmLeadAssignee", fields: [assignedToId], references: [id])
  project     Project?    @relation(fields: [projectId], references: [id])
  createdBy   User?       @relation("CrmLeadCreator", fields: [createdById], references: [id])
  deals       CrmDeal[]
  activities  CrmActivity[]

  @@index([stage])
  @@index([assignedToId])
  @@map("crm_leads")
}

model CrmDeal {
  id           String   @id @default(cuid())
  title        String
  value        Decimal? @db.Decimal(12, 2)
  stage        String   @default("PROPOSAL")
  probability  Int      @default(50)
  closeDate    DateTime? @db.Date
  leadId       String?
  contactId    String?
  companyId    String?
  projectId    String?
  assignedToId String?
  notes        String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  lead        CrmLead?    @relation(fields: [leadId], references: [id])
  contact     CrmContact? @relation(fields: [contactId], references: [id])
  company     CrmCompany? @relation(fields: [companyId], references: [id])
  project     Project?    @relation(fields: [projectId], references: [id])
  assignedTo  User?       @relation("CrmDealAssignee", fields: [assignedToId], references: [id])
  createdBy   User?       @relation("CrmDealCreator", fields: [createdById], references: [id])
  activities  CrmActivity[]

  @@index([stage])
  @@map("crm_deals")
}

model CrmActivity {
  id          String   @id @default(cuid())
  type        String   @default("NOTE")
  subject     String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  leadId      String?
  dealId      String?
  contactId   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  lead        CrmLead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deal        CrmDeal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact     CrmContact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("CrmActivityCreator", fields: [createdById], references: [id])

  @@index([leadId])
  @@index([dealId])
  @@map("crm_activities")
}

model Loan {
  id        String    @id @default(cuid())
  title     String
  amount    Decimal   @db.Decimal(12, 2)
  status    String    @default("PENDING")
  due_date  DateTime?
  notes     String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  @@map("loans")
}

model Receivable {
  id          String    @id @default(cuid())
  client_name String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  status      String    @default("PENDING")
  due_date    DateTime?
  notes       String?
  client_id   String?
  project_id  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@map("receivables")
}

model Invoice {
  id                String    @id @default(cuid())
  invoice_number    String
  client_id         String?
  project_id        String?
  owner_id          String
  line_items        Json
  subtotal          Decimal   @db.Decimal(12, 2)
  tax_rate          Decimal   @db.Decimal(12, 2)
  tax_amount        Decimal   @db.Decimal(12, 2)
  total             Decimal   @db.Decimal(12, 2)
  status            String    @default("DRAFT")
  due_date          DateTime?
  notes             String?
  type              String    @default("INVOICE")
  scope_of_work     String?
  client_location   String?
  important_details String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  // Relations
  client            User?     @relation("ClientInvoices", fields: [client_id], references: [id])
  project           Project?  @relation(fields: [project_id], references: [id])
  owner             User      @relation("OwnerInvoices", fields: [owner_id], references: [id])

  @@map("invoices")
}

model TimeLog {
  id         String    @id @default(cuid())
  task_id    String
  user_id    String
  started_at DateTime  @default(now())
  ended_at   DateTime?
  minutes    Int
  note       String?
  created_at DateTime  @default(now())

  // Relations
  task       Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("time_logs")
}

model SopProgress {
  id            String   @id @default(cuid())
  projectId     String
  level         Int
  stepKey       String
  completedAt   DateTime @default(now())
  completedById String

  // Relations
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  completedBy   User     @relation(fields: [completedById], references: [id], onDelete: Cascade)

  @@map("sop_progress")
}

model ContentMetrics {
  id          String   @id @default(cuid())
  content_id  String
  platform    String   @default("INSTAGRAM")
  post_url    String?
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  reach       Int      @default(0)
  saved       Int      @default(0)
  recorded_at DateTime @default(now())
  created_at  DateTime @default(now())

  // Relations
  content     Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@map("content_metrics")
}
