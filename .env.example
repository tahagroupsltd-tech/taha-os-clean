# .env.example — copy to .env.local and fill in values
# ⚠️  NEVER commit real secrets. This file is safe — it has placeholder values only.

# PostgreSQL connection string
# Local:    postgresql://postgres:password@localhost:5432/taha_os
# Neon.tech: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/taha_os"

# JWT secret — MUST be at least 32 random characters
# Generate: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret-min-32-characters"

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# ⚠️  SECURITY: Set these as Vercel environment variables. Never hardcode.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI — required for the AI assistant chat panel
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o"

# Webhook secret — used by n8n to POST to /api/webhook without a session cookie
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET="change-this-to-a-random-secret"

# Node environment
NODE_ENV="development"

# Show demo account quick-fill buttons on the login page
# Set to "true" in .env.local for dev; NEVER set in Vercel production environment
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS="true"

# ── Google Calendar Integration ──────────────────────────────────────────────
# Setup steps:
# 1. Go to https://console.cloud.google.com → New Project
# 2. APIs & Services → Enable APIs → search "Google Calendar API" → Enable
# 3. APIs & Services → OAuth Consent Screen:
#      - User type: External
#      - App name: Taha Media OS (or anything)
#      - Add scope: https://www.googleapis.com/auth/calendar.events
#      - Add your Gmail as a test user (while app is in "Testing" mode)
# 4. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#      - Application type: Web application
#      - Authorized redirect URIs — add BOTH:
#          http://localhost:3000/api/auth/google-calendar/callback
#          https://taha-os-clean.vercel.app/api/auth/google-calendar/callback
# 5. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-client-secret"
# For LOCAL dev:
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google-calendar/callback"
# For PRODUCTION (set this in Vercel → Environment Variables):
# GOOGLE_REDIRECT_URI="https://taha-os-clean.vercel.app/api/auth/google-calendar/callback"
