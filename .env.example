# .env.example — copy to .env.local and fill in values

# PostgreSQL connection string
# Local:    postgresql://postgres:password@localhost:5432/taha_os
# Neon.tech: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/taha_os"

# JWT secret — must be at least 32 characters, random string
JWT_SECRET="change-this-to-a-long-random-secret-min-32-characters"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI — required for the AI assistant chat panel
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o"

# Webhook secret — used by n8n to POST to /api/webhook without a session cookie
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET="change-this-to-a-random-secret"

# Node environment
NODE_ENV="development"

# Show demo account quick-fill buttons on the login page
# Set to "true" in .env.local for dev; NEVER set in Vercel production environment
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS="true"

# ── Google Calendar Integration ──────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# 1. Enable "Google Calendar API"
# 2. OAuth Consent Screen → External → add scope: calendar.events
# 3. Credentials → OAuth 2.0 Client ID → Web application
# 4. Add Authorized redirect URIs:
#      http://localhost:3000/api/auth/google-calendar/callback   (local dev)
#      https://your-app.vercel.app/api/auth/google-calendar/callback  (production)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Must match one of the redirect URIs you added above
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google-calendar/callback"
